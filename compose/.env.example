# Copy to .env and edit. Used by docker-compose.yml.
STACK_VERSION=9.3.0

# Cluster
CLUSTER_NAME=logging-platform
LICENSE=basic                 # basic | trial (trial unlocks synthetic _source for max LogsDB savings)

# Credentials (change these)
ELASTIC_PASSWORD=changeme-elastic
KIBANA_PASSWORD=changeme-kibana

# Memory per ES node (JVM heap is auto-set to ~50% of this by the container)
ES_MEM_LIMIT=2147483648       # 2 GB

# Ports
ES_PORT=9200
KIBANA_PORT=5601
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO (S3-compatible object store for the frozen tier)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-minio
SNAPSHOT_BUCKET=es-snapshots
